   "source": [
    "import meraki\n",
    "\n",
    "# --- CONFIGURACIÓN ---\n",
    "API_KEY = 'x'  #asegurate de cambiar el token real\n",
    "NETWORK_IDS = [\n",
    "    \n",
    "    \n",
    "    \n",
    "               'L_7915076345xxxxx'\n",
    "               \n",
    "               ] # Puedes agregar más IDs aquí\n",
    "RADIUS_SECRET = 'xxx' #coloca tu Radius Secret\n",
    "\n",
    "dashboard = meraki.DashboardAPI(API_KEY)\n",
    "\n",
    "def desplegar_configuracion():\n",
    "    for network_id in NETWORK_IDS:\n",
    "        print(f\"--- Actualizando red: {network_id} ---\")\n",
    "        \n",
    "        try:\n",
    "            # 1. SSID 1 (Configuración RADIUS + Override)\n",
    "            dashboard.wireless.updateNetworkWirelessSsid(\n",
    "                network_id, \n",
    "                number=0, \n",
    "                name='SSID Name', #cambia nombre SSID real\n",
    "                enabled=True,\n",
    "                authMode='8021x-radius',\n",
    "                encryptionMode='wpa-eap',\n",
    "                wpaEncryptionMode='WPA2 only',\n",
    "                radiusServers=[\n",
    "                    {'host': 'IP-Radius', 'port': radius-port, 'secret': RADIUS_SECRET},\n", #cambia direccion ip y puerto del servidor radius
    "                    {'host': 'IP-Radius', 'port': radius-port, 'secret': RADIUS_SECRET}\n",
    "                ],\n",
    "                # Esta es la opción  (RADIUS response can override VLAN tag)\n",
    "                radiusOverride=True, \n",
    "                ipAssignmentMode='Bridge mode'\n",
    "            )\n",
    "            print(\"OK: FARMATODO actualizado con RADIUS Override.\")\n",
    "\n",
    "            # 2. SSID 2 (Abierto + VLAN 752)\n",
    "            dashboard.wireless.updateNetworkWirelessSsid(\n",
    "                network_id, \n",
    "                number=1, \n",
    "                name='FARMATODO_CLIENTES',\n",
    "                enabled=True,\n",
    "                authMode='open',\n",
    "                ipAssignmentMode='Bridge mode', # Necesario para usar VLANs de la red\n",
    "                useVlanTagging=True,\n",
    "                defaultVlanId=752\n",
    "            )\n",
    "            print(\"OK: FARMATODO_CLIENTES actualizado (VLAN 752).\")\n",
    "\n",
    "        except meraki.APIError as e:\n",
    "            print(f\"Error de API en {network_id}: {e}\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    desplegar_configuracion()"
   ]
  }
 ],
